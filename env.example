API_BASE_URL=https://api.akhbaralyawm.com
NEXT_PUBLIC_ASSET_HOST=https://www.akhbaralyawm.com
# Per-locale asset hosts. When unset, the EN/FR hosts are derived by swapping
# the leading subdomain of NEXT_PUBLIC_ASSET_HOST (www.* -> en.*, www.* -> fr.*).
# Override only if your CDN layout differs from the legacy domain pattern.
# NEXT_PUBLIC_ASSET_HOST_AR=https://www.akhbaralyawm.com
# NEXT_PUBLIC_ASSET_HOST_EN=https://en.akhbaralyawm.com
# NEXT_PUBLIC_ASSET_HOST_FR=https://fr.akhbaralyawm.com
NEXT_PUBLIC_SITE_URL=https://www.akhbaralyawm.com
AKHBAR_PREVIEW_SHARED_SECRET=CHANGE_ME

# Optional overrides for v1 paths. Defaults match the canonical v1 contract
# (no .ashx). Only set these if the backend exposes legacy aliases.
# API_CMS_PAGE_PATH=/v1/pages/by-id
# API_AUTHOR_ARTICLES_PATH=/v1/news
# API_AUTHOR_QUERY_KEY=author

AUTHOR_ARCHIVE_PAGE_SIZE=12
CATEGORY_ARCHIVE_PAGE_SIZE=12
SEARCH_PAGE_SIZE=12